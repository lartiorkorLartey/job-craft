DATABASE_URL="postgresql://user:password@localhost:5432/jobcraft"
JWT_SECRET="change-me-to-a-long-random-string"
PORT=5000

# ── LLM provider config ──────────────────────────────────────────────────────
# Set LLM_API_KEY to any provider's key — the provider is auto-detected from
# the key prefix, or you can set LLM_PROVIDER explicitly.
#
# Auto-detected prefixes:
#   sk-ant-*  →  anthropic
#   gsk_*     →  groq
#   sk-*      →  openai
#
# Explicit provider values (set LLM_PROVIDER to one of):
#   anthropic | openai | groq | mistral | together | perplexity | ollama | custom
#
# LLM_MODEL     — override the default model (optional)
# LLM_BASE_URL  — required for ollama/custom; optional override for others

LLM_API_KEY=""
# LLM_PROVIDER="groq"
# LLM_MODEL="llama-3.3-70b-versatile"
# LLM_BASE_URL="http://localhost:11434/v1"

# Legacy Anthropic key (still works if LLM_API_KEY is not set)
# ANTHROPIC_API_KEY="sk-ant-..."
